# Application Configuration
APP_NAME="Production-Grade AI Chatbot Backend"
APP_ENV="development" # development, production
API_V1_STR="/api/v1"

# Database Configuration (PostgreSQL)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="securepassword"
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="ai_chatbot"

# Async Database URL (auto-generated or override here)
# DATABASE_URL="postgresql+asyncpg://postgres:securepassword@localhost:5432/ai_chatbot"

# Vector Database Configuration (ChromaDB)
CHROMADB_HOST="localhost"
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIRECTORY="./chroma_db"

# LLM Configuration (Gemini API)
GEMINI_API_KEY="your-gemini-api-key-here"
